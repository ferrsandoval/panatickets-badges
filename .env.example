# Copiar a .env o .env.local.
# Vercel: WEBHOOK_SECRET y DATABASE_URL se configuran en el proyecto (Storage + Env).
# Local: usa "vercel env pull .env.local" o una base Postgres (Neon/Supabase) y pega aquí DATABASE_URL.

WEBHOOK_SECRET=tu_token_aqui
# Ejemplo Postgres (Neon/Vercel Postgres): postgresql://user:pass@host/db?sslmode=require
DATABASE_URL="postgresql://..."

# Multi-proyecto (todas las bases en el mismo dominio):
# Cada proyecto puede tener su propia base de datos. El backend usará el parámetro
# ?project=... de la URL para elegir la conexión. Para un project="feria_panama":
#   - CodeREADr:  https://tu-dominio.com/api/webhook/codereadr?token=...&project=feria_panama
#   - Cola web:   https://tu-dominio.com/?project=feria_panama
#   - Etiqueta:   https://tu-dominio.com/label/ID_DEL_JOB?project=feria_panama
# Debes definir una variable por proyecto con el patrón:
#   DATABASE_URL_<NOMBRE_NORMALIZADO>
# donde <NOMBRE_NORMALIZADO> es el valor de "project" en mayúsculas y con solo letras,
# números y guiones bajos. Ejemplos:
#   project=feria_panama    -> DATABASE_URL_FERIA_PANAMA="postgresql://..."
#   project=cliente1        -> DATABASE_URL_CLIENTE1="postgresql://..."
#   project=expo-2025-mx    -> DATABASE_URL_EXPO_2025_MX="postgresql://..."

# Ejemplo concreto – Expos 2026:
# project=expo_logistica_2026   -> DATABASE_URL_EXPO_LOGISTICA_2026="postgresql://..."
# project=expo_turismo_2026     -> DATABASE_URL_EXPO_TURISMO_2026="postgresql://..."
# project=expo_comer_2026       -> DATABASE_URL_EXPO_COMER_2026="postgresql://..."
# project=expo_tech_2026        -> DATABASE_URL_EXPO_TECH_2026="postgresql://..."
# project=expo_electronica_2026 -> DATABASE_URL_EXPO_ELECTRONICA_2026="postgresql://..."
